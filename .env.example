# All Volleyball Marketing Ops Dashboard — environment contract.
# The dashboard boots fully on seed data with NONE of these set.
# Each connector is gated on its key and falls back to seed if absent or failing.
# Tokens must live in a server route, never in client code or this repo.

# Asana: live Rocks sync. Project GID 1215155436119479.
ASANA_TOKEN=

# Klaviyo: campaign metrics (opens, clicks, revenue) for the Campaigns view.
KLAVIYO_API_KEY=

# n8n: workflow run status for the Automation view.
# Base: https://richardbiticon.app.n8n.cloud
N8N_API_KEY=

# Not implemented yet (typed stubs only). Budget uses seed figures until these land.
# META_ACCESS_TOKEN=
# GOOGLE_ADS_TOKEN=
# ATTENTIVE_API_KEY=
